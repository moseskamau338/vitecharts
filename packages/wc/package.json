{
  "name": "@vitecharts/wc",
  "version": "1.0.0",
  "description": "ViteCharts Web Component — <vitecharts-chart> for any framework or none.",
  "license": "Apache-2.0",
  "author": "Moses Kamau",
  "homepage": "https://github.com/moseskamau338/vitecharts#readme",
  "bugs": "https://github.com/moseskamau338/vitecharts/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moseskamau338/vitecharts.git",
    "directory": "packages/wc"
  },
  "type": "module",
  "sideEffects": [
    "./dist/index.js"
  ],
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitecharts/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
