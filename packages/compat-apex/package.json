{
  "name": "@vitecharts/compat-apex",
  "version": "1.0.0",
  "description": "Best-effort translation of ApexCharts options to ViteCharts options.",
  "license": "Apache-2.0",
  "author": "Moses Kamau",
  "homepage": "https://github.com/moseskamau338/vitecharts#readme",
  "bugs": "https://github.com/moseskamau338/vitecharts/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moseskamau338/vitecharts.git",
    "directory": "packages/compat-apex"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitecharts/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
