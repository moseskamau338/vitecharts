{
  "name": "vitecharts-monorepo",
  "version": "0.0.0",
  "private": true,
  "author": "Moses Kamau <moseskamau338@gmail.com>",
  "description": "Animated, framework-agnostic charting library built on Observable Plot — an open ApexCharts alternative.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "dev": "pnpm --filter @vitecharts/sandbox dev",
    "test": "pnpm -r --filter=./packages/* test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:exports": "pnpm -r --filter=./packages/* check:exports",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm check:exports && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "publint": "^0.3.21",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
