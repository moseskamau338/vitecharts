{
  "name": "plotex-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Animated, framework-agnostic charting library built on Observable Plot — an open ApexCharts alternative.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "dev": "pnpm --filter @plotex/sandbox dev",
    "test": "pnpm -r --filter=./packages/* test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
